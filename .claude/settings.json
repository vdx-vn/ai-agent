{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "DISPLAY=:0 notify-send 'Claude Code' 'Needs your attention' --icon=dialog-question 2>/dev/null || true",
            "async": false
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"tooling/materialization/suggest_odoo_skill_setup.py\" --mode session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"tooling/materialization/suggest_odoo_skill_setup.py\" --mode prompt-submit",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
